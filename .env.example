CLIP_ADDR=http://localhost:8001
SIGLIP2_ADDR=http://localhost:8002
QDRANT_ADDR=localhost:6334
CLIP_DIM=512
SIGLIP2_DIM=768
HTTP_ADDR=:8080
CONCURRENCY=4
ASSET_BACKEND=none # Options: 'none' (remote-only), 's3' (stored thumbnails)
SKIP_FULL_IMAGE_SAVE=true # When using 's3', only store thumbnails, keep full images remote
WORKER_MODE=indexer
JOB_BACKEND=memory
JOB_STORE_DSN=postgres://iris:iris@localhost:5432/iris?sslmode=disable
ADMIN_API_KEY=change-me
JOB_POLL_INTERVAL=1s
LEASE_DURATION=30s
FETCH_RETRIES=2
FETCH_RETRY_BACKOFF=500ms
HOST_CONCURRENCY=2
HTTP_CACHE_TTL=10m
ROBOTS_CACHE_TTL=24h
CACHE_PRUNE_INTERVAL=15m
CACHE_PRUNE_BATCH=500
